/* 体重记录页样式 — 1:1 迁移自 WeightRecord.vue
   px → rpx 按 1px = 2rpx 换算 */

.page {
  min-height: 100vh;
  background: var(--color-surface);
}

/* ── 导航栏 ── */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
}

.nav-back-icon {
  font-size: 40rpx;
  color: var(--color-primary);
}

.nav-title {
  font-family: var(--font-sans);
  font-size: var(--text-2xl);
  font-weight: var(--font-weight-bold);
  line-height: var(--leading-tight);
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

.nav-placeholder {
  width: 64rpx;
}

.page-body {
  padding: 0 32rpx 64rpx;
}

/* ── 当前体重卡片 ── */
.current-card {
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.current-label {
  display: block;
  margin-bottom: 8rpx;
}

.current-main-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.current-weight {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: 96rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.03em;
  line-height: 1.1;
}

.current-unit {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.current-change-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.current-change {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
}

.current-change-label {
  /* inherits typography-caption */
}

.current-last {
  display: block;
}

/* ── 记录体重卡片 ── */
.record-card {
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.record-title {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.record-input-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.weight-input-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 96rpx;
  background: var(--color-surface-muted);
}

.weight-input {
  flex: 1;
  min-width: 0;
  background: transparent;
  border: none;
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.weight-input-placeholder {
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  color: var(--color-primary-light);
}

.weight-input-unit {
  white-space: nowrap;
  margin-left: 8rpx;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.record-bottom-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.date-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 88rpx;
  background: var(--color-surface-muted);
}

.date-text {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.date-icon {
  margin-left: 12rpx;
  font-size: 28rpx;
  color: var(--color-primary-light);
}

.save-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 48rpx;
  border-radius: var(--radius-lg);
  white-space: nowrap;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-training-main);
  color: var(--color-surface);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
}

/* ── 体重趋势图卡片 ── */
.chart-card {
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.chart-title {
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
}

.chart-range {
  /* inherits typography-caption */
}

.chart-container {
  width: 100%;
  position: relative;
}

.weight-chart-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* ── 历史记录卡片 ── */
.history-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 40rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.history-title {
  display: block;
  padding: 32rpx 32rpx 8rpx;
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.history-item-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.history-date {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--color-primary);
}

.history-weight {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.history-change {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
}

.history-footer {
  padding: 24rpx 32rpx;
  border-top: 2rpx solid var(--color-border-light);
}

.history-footer-text {
  display: block;
  text-align: center;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-training-main);
}
