/* 设置与导出页样式
   1:1 迁移自 SettingsExport.vue + 设计稿设置与导出.html
   px → rpx 换算（1px = 2rpx），0.5px 发丝线 → 1rpx，CSS 变量保留 */

.page {
  padding: 0 32rpx 80rpx;
}

/* ── 头部 ── */
.header {
  padding: 48rpx 16rpx 32rpx;
}

/* ── Section 通用 ── */
.section {
  margin-bottom: 48rpx;
  padding: 0 16rpx;
}
.section-title {
  display: block;
  padding: 0 8rpx;
  margin-bottom: 12rpx;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary-light);
  text-transform: uppercase;
}
.section-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

/* ── 行通用 ── */
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}
.row--border {
  border-bottom: 1rpx solid var(--color-border);
}
.row-content {
  min-width: 0;
  flex: 1;
  margin-right: 24rpx;
}
.row-label {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.row-caption {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary-light);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.row-caption--truncate {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* ── 行右侧值（单位/取整，muted 风格） ── */
.row-value {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.row-value--muted {
  gap: 8rpx;
  color: var(--color-primary-light);
  font-family: var(--font-sans);
  font-size: var(--text-base);
}
.row-value--mono {
  gap: 16rpx;
  font-family: var(--font-mono);
  font-size: var(--text-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.row-icon {
  font-size: 28rpx;
}

/* ── 组间休息 ± 按钮 ── */
.rest-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}
.rest-icon {
  font-size: 28rpx;
  color: var(--color-primary-light);
}
.rest-value {
  font-family: var(--font-mono);
  font-size: var(--text-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}

/* ── iOS 风格 Toggle ── */
/* 原 Vue：51×31px，圆角 15.5px，thumb 27×27px，top 2px，right 2px(on)/22px(off)
   转 rpx：102×62rpx，圆角 31rpx，thumb 54×54rpx，top 4rpx，right 4rpx(on)/44rpx(off) */
.toggle {
  width: 102rpx;
  height: 62rpx;
  border-radius: 31rpx;
  position: relative;
  flex-shrink: 0;
  transition: background 250ms cubic-bezier(0.25, 0.1, 0.25, 1);
}
.toggle--on {
  background: var(--state-success);
}
.toggle--off {
  background: var(--color-border);
}
.toggle-thumb {
  width: 54rpx;
  height: 54rpx;
  background: var(--color-surface);
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: right 250ms cubic-bezier(0.25, 0.1, 0.25, 1);
}
.toggle-thumb--on {
  right: 4rpx;
}
.toggle-thumb--off {
  right: 44rpx;
}

/* ── 数据管理：导出/导入 action ── */
.row-action {
  flex-shrink: 0;
  color: var(--color-training-main);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-medium);
}

/* ── 周期行右箭头 ── */
.row-chevron {
  font-size: 32rpx;
  color: var(--color-border);
  flex-shrink: 0;
}

/* ── 数据存储：模式徽标（Task 16A） ── */
/* 胶囊式徽标，复用全局设计令牌；云端用 info 色，本地用中性色 */
.storage-badge {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-normal);
}
.storage-badge--cloud {
  background: var(--state-info-bg);
  color: var(--color-training-main);
}
.storage-badge--local {
  background: var(--color-primary-subtle);
  color: var(--color-primary-light);
}

/* ── 导入冲突提示（placeholder，Task 16A 实现完整 UI） ── */
.conflict-banner {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  background: var(--state-warning-bg);
}
.conflict-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.conflict-icon {
  font-size: 28rpx;
  color: var(--state-warning);
  flex-shrink: 0;
  margin-top: 2rpx;
}
.conflict-text {
  display: flex;
  flex-direction: column;
}
.conflict-title {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.conflict-desc {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}
.conflict-placeholder {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  font-style: italic;
}
