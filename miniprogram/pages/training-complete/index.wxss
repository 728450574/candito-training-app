/* 训练完成总结页样式 — 迁移自 TrainingComplete.vue
   1:1 还原设计稿，px → rpx (1px = 2rpx)
   引用全局 CSS 变量 (见 assets/styles/theme.wxss) */

.complete-page {
  min-height: 100vh;
  background: var(--color-surface);
}

/* ── Loading / Empty ── */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.empty-text {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-training-main);
  color: var(--color-surface);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  line-height: 1.4;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* ── Main ── */
.complete-main {
  max-width: 768rpx;
  margin: 0 auto;
  padding: 64rpx 32rpx 192rpx;
}

/* ── Completion Header ── */
.complete-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 48rpx;
}

.check-circle {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-full);
  background: var(--state-success);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.check-icon {
  font-size: 64rpx;
  color: #fff;
}

.complete-title {
  font-family: var(--font-sans);
  font-size: var(--text-4xl);
  font-weight: var(--font-weight-bold);
  line-height: var(--leading-tight);
  letter-spacing: -0.02em;
  color: var(--color-primary);
  text-align: center;
  word-break: keep-all;
  overflow-wrap: break-word;
}

.complete-subtitle {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary-light);
  text-align: center;
  margin-top: 16rpx;
}

/* ── Summary Card ── */
.summary-card {
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.summary-title {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.summary-exercise {
  /* 每个动作块 */
}

.ex-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.ex-name {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.ex-count {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  color: var(--state-success);
}

.ex-sets {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-left: 8rpx;
  margin-bottom: 24rpx;
}

.ex-set-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
}

.ex-set-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  opacity: 0.5;
}

.ex-set-value {
  flex: 1;
  text-align: center;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
}

.ex-set-icon {
  font-size: 28rpx;
}

.ex-divider {
  height: 2rpx;
  margin-bottom: 24rpx;
  background: var(--color-border-light);
}

/* ── Stats Grid ── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stats-cell {
  border-radius: var(--radius-xl);
  padding: 24rpx;
  text-align: center;
  background: var(--color-surface-muted);
}

.stats-value {
  display: block;
  font-family: var(--font-mono);
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.stats-label {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  color: var(--color-primary-light);
  margin-top: 4rpx;
}

/* ── MR10 Notice ── */
.mr10-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: var(--state-info-bg);
  box-shadow: var(--shadow-card);
}

.mr10-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-full);
  background: var(--state-info);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.mr10-icon {
  font-size: 32rpx;
  color: #fff;
}

.mr10-content {
  flex: 1;
  min-width: 0;
}

.mr10-title {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  color: var(--state-info);
  line-height: var(--leading-normal);
}

.mr10-desc {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-regular);
  color: var(--color-primary-light);
  line-height: var(--leading-normal);
  margin-top: 8rpx;
}

/* ── Form Cards (Body Weight / Notes / Feeling) ── */
.form-card {
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.form-card-feeling {
  margin-bottom: 48rpx;
}

.form-title {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.weight-input-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.weight-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 80rpx;
  background: var(--color-surface-muted);
  border: 2rpx solid var(--color-border-light);
}

.weight-input {
  flex: 1;
  background: transparent;
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  height: 80rpx;
}

.weight-input-placeholder {
  color: var(--color-primary-light);
  font-family: var(--font-mono);
  font-weight: var(--font-weight-regular);
}

.weight-unit {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
  flex-shrink: 0;
}

.form-hint {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 16rpx;
}

.notes-textarea {
  width: 100%;
  background: var(--color-surface-muted);
  border: 2rpx solid var(--color-border-light);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
  line-height: var(--leading-normal);
  box-sizing: border-box;
  min-height: 144rpx;
}

.notes-placeholder {
  color: var(--color-primary-light);
}

/* ── Feeling Stars ── */
.stars-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.star-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
}

.star-icon {
  font-size: 48rpx;
  line-height: 1;
}

.stars-labels {
  display: flex;
  justify-content: space-between;
}

.stars-label {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

/* ── Action Buttons ── */
.actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.checkin-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--state-success);
  color: #fff;
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  line-height: 96rpx;
  padding: 0;
  border: none;
}

.checkin-btn::after {
  border: none;
}

.checkin-btn-disabled {
  opacity: 0.6;
}

.back-today-link {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
  text-decoration: underline;
  text-underline-offset: 4rpx;
  padding: 8rpx 16rpx;
}
