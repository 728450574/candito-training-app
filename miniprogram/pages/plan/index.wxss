/* 训练计划页样式 — 1:1 迁移自 TrainingPlan.vue
   px → rpx 按 1px = 2rpx 换算，颜色/字号引用全局 CSS 变量 */

.page {
  min-height: 100vh;
  background: var(--color-surface);
}

/* ── 顶部导航栏 ── */
.nav-header {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-bottom: 1rpx solid var(--color-border-light);
}

.nav-back {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-left: -8rpx;
}

.nav-back-icon {
  font-size: 40rpx;
  color: var(--color-training-main);
}

.nav-title {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-family: var(--font-sans);
  font-size: 34rpx;
  font-weight: var(--font-weight-semibold);
  letter-spacing: -0.02em;
  color: var(--color-primary);
}

.nav-placeholder {
  width: 64rpx;
}

/* ── 当前位置横幅 ── */
.position-banner {
  margin: 32rpx 32rpx 0;
  border-radius: var(--radius-lg);
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-surface-muted);
}

.position-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.position-tag {
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  color: var(--color-primary-light);
}

.position-text {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-primary);
}

.position-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.position-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
}

/* ── 周选择器 ── */
.week-tabs {
  margin-top: 32rpx;
  white-space: nowrap;
}

.week-tabs-inner {
  display: inline-flex;
  gap: 8rpx;
  padding: 0 32rpx;
}

.week-tab {
  flex-shrink: 0;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  font-size: var(--text-xs);
  border-radius: var(--radius-md);
}

.week-tab-check {
  font-size: 24rpx;
}

.week-tab-label {
  line-height: 1;
}

/* ── 周内容 ── */
.week-content {
  padding: 32rpx 32rpx 64rpx;
  margin-top: 32rpx;
}

.week-title {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  letter-spacing: -0.01em;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.day-card {
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid var(--color-border);
  background: var(--color-surface);
  box-shadow: var(--shadow-elevated);
}

.day-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.day-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-md);
}

.day-badge-icon {
  font-size: 24rpx;
}

.day-badge-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  background: var(--state-info);
}

.day-badge-text {
  line-height: 1;
}

.day-weekday {
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  color: var(--color-primary-light);
}

.day-workout-type {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.day-exercises {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ex-divider {
  height: 2rpx;
  background: var(--color-border-light);
}

.ex-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--text-sm);
}

.ex-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.ex-weight {
  font-family: var(--font-mono);
  font-weight: var(--font-weight-semibold);
  white-space: nowrap;
  flex-shrink: 0;
  font-size: var(--text-sm);
}

.empty-state {
  padding: 96rpx 0;
  text-align: center;
}

/* ── 无周期 ── */
.no-cycle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.no-cycle-text {
  margin-bottom: 32rpx;
}

.create-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-training-main);
  color: var(--color-surface);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
}
