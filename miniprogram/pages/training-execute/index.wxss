/* 训练执行页样式 — 迁移自 TrainingExecution.vue
   1:1 还原设计稿，px → rpx (1px = 2rpx)
   引用全局 CSS 变量 (见 assets/styles/theme.wxss) */

.exec-page {
  min-height: 100vh;
  background: var(--color-surface);
}

/* ── Top Navigation Bar ── */
.exec-header {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  height: 96rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: var(--color-surface);
  border-bottom: 1rpx solid var(--color-border-light);
  /* 状态栏占位 */
  padding-top: env(safe-area-inset-top);
  min-height: calc(96rpx + env(safe-area-inset-top));
}

.header-back,
.header-pause {
  display: inline-flex;
  height: 64rpx;
  width: 64rpx;
  align-items: center;
  justify-content: center;
}

.header-back-icon {
  font-size: 32rpx;
  color: var(--color-training-main);
}

.header-title {
  flex: 1;
  text-align: center;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  letter-spacing: -0.01em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 16rpx;
}

.header-pause-icon {
  font-size: 32rpx;
  color: var(--color-primary-light);
}

/* ── Loading / Error ── */
.exec-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.exec-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.exec-error-msg {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
  margin-bottom: 32rpx;
}

.exec-error-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-training-main);
  color: var(--color-surface);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
}

/* ── Content ── */
.exec-content {
  padding-bottom: 48rpx;
}

/* ── Timer Bar ── */
.timer-section {
  padding: 40rpx 32rpx 32rpx 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.timer-left {
  display: flex;
  flex-direction: column;
}

.timer-label {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
}

.timer-elapsed {
  font-family: var(--font-mono);
  font-size: var(--text-4xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  white-space: nowrap;
}

.timer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rest-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
}

.rest-circle-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: var(--radius-full);
  background: var(--color-surface);
}

.rest-circle-text {
  font-family: var(--font-mono);
  font-size: 16rpx;
  color: var(--color-primary-light);
}

.rest-info {
  display: flex;
  flex-direction: column;
}

.rest-label {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  white-space: nowrap;
}

.rest-value {
  font-family: var(--font-mono);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  white-space: nowrap;
}

/* ── Current Exercise ── */
.current-section {
  padding: 0 32rpx 32rpx 32rpx;
}

.ex-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.ex-name {
  font-family: var(--font-sans);
  font-size: var(--text-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.02em;
  line-height: var(--leading-tight);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ex-badge {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.ex-set-progress {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
  white-space: nowrap;
  margin-bottom: 32rpx;
}

/* Target */
.ex-target {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
  padding: 16rpx 24rpx;
  background: var(--color-surface-muted);
  border-radius: var(--radius-md);
}

.ex-target-icon {
  font-size: 24rpx;
  color: var(--color-primary-light);
}

.ex-target-label {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
  white-space: nowrap;
}

.ex-target-value {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  white-space: nowrap;
}

.ex-target-x {
  color: var(--color-primary-light);
}

/* Weight Input */
.weight-input-section {
  margin-bottom: 32rpx;
}

.weight-input-label {
  display: block;
  margin-bottom: 16rpx;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
  white-space: nowrap;
}

.weight-input-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 0 8rpx 16rpx 8rpx;
  border-bottom: 4rpx solid var(--color-primary);
}

.weight-input {
  flex: 1;
  font-family: var(--font-mono);
  font-size: var(--text-4xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
}

.weight-input-unit {
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
  white-space: nowrap;
}

/* Reps Selection */
.reps-section {
  margin-bottom: 40rpx;
}

.reps-label {
  display: block;
  margin-bottom: 16rpx;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
  white-space: nowrap;
}

.reps-list {
  display: flex;
  gap: 16rpx;
}

.rep-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary-light);
  background: var(--color-surface-muted);
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
}

.rep-btn-selected {
  font-weight: var(--font-weight-bold);
  color: var(--color-surface);
  background: var(--color-training-main);
}

/* Complete Set CTA */
.complete-set-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-surface);
  background: var(--state-success);
  height: 104rpx;
  border-radius: var(--radius-lg);
}

.complete-set-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

/* ── Set List ── */
.set-list-section {
  padding: 0 32rpx 32rpx 32rpx;
}

.set-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.set-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
}

.set-circle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-full);
}

.set-check-icon {
  font-size: 20rpx;
  color: var(--color-primary-light);
}

.set-circle-text {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-bold);
  white-space: nowrap;
}

.set-label-wrap {
  flex: 1;
  min-width: 0;
}

.set-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
}

.set-value {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
}

/* ── MR10 Notice ── */
.mr10-notice {
  margin: 32rpx 40rpx 32rpx 40rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--state-info-bg);
  border: 1rpx solid rgba(0, 122, 255, 0.15);
}

.mr10-inner {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.mr10-icon {
  font-size: 22rpx;
  color: var(--state-info);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.mr10-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.mr10-title {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}

.mr10-desc {
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 4rpx;
}

.mr10-hint {
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 4rpx;
}

/* ── Next Exercise ── */
.next-section {
  padding: 0 32rpx 64rpx 32rpx;
}

.next-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--color-surface-muted);
  border-radius: var(--radius-md);
}

.next-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.next-icon {
  font-size: 24rpx;
  color: var(--color-primary-light);
}

.next-label {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
  white-space: nowrap;
}

.next-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.next-name {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.next-badge {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.next-target-row {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
  padding: 0 8rpx;
}

.next-target {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  white-space: nowrap;
}

/* ── All Done ── */
.all-done-section {
  padding: 0 32rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
}

.all-done-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--state-success-bg);
  margin-bottom: 24rpx;
}

.all-done-icon {
  font-size: 48rpx;
  color: var(--state-success);
}

.all-done-title {
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  line-height: var(--leading-tight);
}

.all-done-desc {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
  margin-top: 8rpx;
}

/* ── Finish Button ── */
.finish-section {
  padding: 32rpx 40rpx 48rpx 40rpx;
  margin-top: 32rpx;
}

.finish-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
}

.finish-btn-active {
  background: var(--state-success);
  color: var(--color-surface);
}

.finish-btn-inactive {
  background: var(--color-border-light);
  color: var(--color-primary-light);
}

.finish-btn-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
