/* 自定义动作页样式 — 1:1 迁移自 CustomExercise.vue
   px → rpx 按 1px = 2rpx 换算 */

.page {
  min-height: 100vh;
  background: var(--color-surface);
}

/* ── 导航栏 ── */
.nav-header {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  border-bottom: 2rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.92);
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
}

.nav-back-icon {
  font-size: 40rpx;
  color: var(--color-primary);
}

.nav-title {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

.nav-placeholder {
  width: 72rpx;
}

.page-body {
  padding: 40rpx 32rpx 64rpx;
}

/* ── 通用 section ── */
.section {
  margin-bottom: 40rpx;
}

.section-config {
  margin-bottom: 64rpx;
}

.section-label {
  display: block;
  margin-bottom: 20rpx;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
}

.section-label-light {
  font-weight: var(--font-weight-regular);
}

/* ── 动作位置选择列表 ── */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.category-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 28rpx;
}

.radio-wrap {
  display: flex;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: var(--radius-full);
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-label {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-sublabel {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

/* ── 动作名称输入 ── */
.name-input-wrap {
  padding-bottom: 8rpx;
  border-bottom: 3rpx solid var(--color-border);
}

.name-input {
  width: 100%;
  background: transparent;
  border: none;
  padding: 20rpx 0;
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-medium);
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

.name-input-placeholder {
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-regular);
  color: var(--color-primary-light);
}

/* ── 推荐选择 ── */
.preset-scroll {
  width: 100%;
  white-space: nowrap;
}

.preset-row {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.preset-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
}

/* ── 默认组数配置 ── */
.config-card {
  border-radius: var(--radius-xl);
  padding: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-elevated);
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.config-group {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.config-label {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary);
}

.config-value-box {
  display: flex;
  width: 96rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  background: var(--color-surface-muted);
  border-radius: var(--radius-md);
}

.config-value {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.config-unit {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.config-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--color-border-light);
}

.config-hint {
  display: block;
  margin-top: 20rpx;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

/* ── 操作按钮 ── */
.action-section {
  /* no extra spacing */
}

.confirm-btn {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-semibold);
  background: var(--color-training-main);
  color: var(--color-surface);
}

.cancel-btn {
  margin-top: 32rpx;
  text-align: center;
  padding: 8rpx 0;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
}
