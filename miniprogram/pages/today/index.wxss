/* 今日训练页样式
   1:1 迁移自 TodayTraining.vue + 设计稿今日训练.html / 休息日.html
   px → rpx 换算（1px = 2rpx），CSS 变量保留 */

.page {
  padding: 0 32rpx 80rpx;
}

/* ── 通用卡片 ── */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-elevated);
}

.icon-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* ── 无活跃周期 ── */
.no-cycle {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 40rpx 32rpx;
  text-align: center;
}
.no-cycle-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-full);
  background: var(--color-training-main);
  opacity: 0.1;
}
.no-cycle-icon {
  font-size: 56rpx;
  color: var(--color-training-main);
}
.no-cycle-title {
  margin-top: 40rpx;
}
.no-cycle-caption {
  margin-top: 16rpx;
  color: var(--color-primary-light);
}
.no-cycle-btn {
  margin-top: 64rpx;
}

/* ── 按钮通用 ── */
.btn-primary-full {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--color-training-main);
  color: var(--color-surface);
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
}
.btn-secondary-full {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-full);
  background: var(--color-surface-muted);
  color: var(--color-primary);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
}

/* ── 问候区域 ── */
.greeting-section {
  padding: 16rpx 40rpx 32rpx;
}
.greeting-title {
  margin-top: 8rpx;
  display: block;
}

/* ── 暂停卡片 ── */
.card-paused-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.card-paused-info {
  display: flex;
  flex-direction: column;
}
.card-paused-info .typography-subtitle {
  display: block;
}
.card-paused-info .typography-caption {
  display: block;
}
.card-paused-footer {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

/* ── 跳过卡片 ── */
.card-skipped {
  border-left: 6rpx solid var(--color-primary-light);
}
.card-skipped-footer {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

/* ── 快捷操作 ── */
.quick-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 40rpx;
  margin-top: 48rpx;
}
.quick-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}
.quick-action-icon {
  font-size: 36rpx;
  color: var(--color-training-main);
  margin-bottom: 8rpx;
}
.quick-action-label {
  font-size: var(--text-xs);
  color: var(--color-primary);
}

/* ── 休息日 ── */
.rest-header {
  padding: 0 40rpx 32rpx;
}
.rest-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--color-primary-light);
}
.card-rest {
  border-left: 6rpx solid var(--color-training-main);
  margin: 0 40rpx;
}
.rest-next-title {
  display: block;
  margin-bottom: 8rpx;
}
.rest-next-date {
  display: block;
  margin-bottom: 40rpx;
}
.rest-countdown {
  font-family: var(--font-mono);
  font-size: 72rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-training-main);
  letter-spacing: -0.02em;
  line-height: var(--leading-tight);
  margin-bottom: 40rpx;
}
.rest-content {
  padding-top: 32rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.rest-exercises {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* ── 练习行 ── */
.exercise-row-sm {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.exercise-dot-sm {
  display: inline-flex;
  width: 12rpx;
  height: 12rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.exercise-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.exercise-dot {
  display: inline-flex;
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.exercise-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 待训练卡片 ── */
.card-pending {
  border-left: 6rpx solid var(--color-warm);
  margin: 0 40rpx;
}
.card-pending-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.week-badge {
  display: inline-flex;
  align-items: center;
  border-radius: var(--radius-sm);
  padding: 8rpx 20rpx;
  background: var(--color-primary-subtle);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  font-family: var(--font-sans);
}
.duration-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.duration-badge .iconfont {
  color: var(--color-primary-light);
}
.pending-workout-type {
  display: block;
  margin-bottom: 32rpx;
}
.pending-exercises {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

/* ── 统计行 ── */
.stats-row {
  display: flex;
  align-items: stretch;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  margin: 0 40rpx;
  margin-top: 48rpx;
}
.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
}
.stat-divider {
  width: 1rpx;
  align-self: stretch;
  background: var(--color-border);
}
.stat-value {
  font-family: var(--font-mono);
  font-size: var(--text-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  white-space: nowrap;
}
.stat-value-light {
  color: var(--color-primary-light);
}
.stat-value-accent {
  color: var(--color-training-main);
}
.stat-label {
  margin-top: 8rpx;
  display: block;
}

/* ── 链接按钮 ── */
.center-row {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}
.link-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--text-sm);
}
.link-btn-accent {
  color: var(--color-training-main);
}
.link-btn-muted {
  color: var(--color-primary-light);
}
.link-btn-warning {
  color: var(--state-warning);
}

/* ── 已完成 ── */
.completed-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding: 0 40rpx;
}
.completed-info {
  display: flex;
  flex-direction: column;
}
.completed-info .typography-subtitle {
  display: block;
}
.completed-info .typography-caption {
  display: block;
}
.card-completed {
  border-radius: var(--radius-xl);
  margin: 0 40rpx;
}
.completed-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.completed-card-title {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.detail-link {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: var(--text-xs);
  color: var(--color-training-main);
}
.completed-stats {
  display: flex;
  align-items: stretch;
}
.completed-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}
.completed-stat + .completed-stat {
  border-left: 1rpx solid var(--color-border-light);
}
.completed-stat-label {
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 4rpx;
}
.completed-feeling {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.completed-feeling-label {
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}
.completed-feeling-value {
  font-size: var(--text-sm);
  color: var(--color-primary);
}

.body-weight-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: var(--radius-md);
  padding: 24rpx;
  background: var(--color-surface-muted);
  margin: 0 40rpx;
}
.body-weight-label {
  font-size: var(--text-sm);
  color: var(--color-primary);
}
.body-weight-value {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-training-main);
}

.next-training-card {
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin: 32rpx 40rpx 0;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}
.next-training-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.next-training-title {
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.next-training-tomorrow {
  font-size: var(--text-xs);
  color: var(--color-training-main);
}
.next-training-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.next-training-info {
  display: flex;
  flex-direction: column;
}
.next-training-type {
  font-size: var(--text-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.next-training-detail {
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 4rpx;
}
