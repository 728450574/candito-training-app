/* 进度统计页样式
   1:1 迁移自 ProgressStats.vue + 设计稿进度统计.html
   px → rpx 换算（1px = 2rpx），CSS 变量保留 */

.page {
  padding: 0 32rpx 96rpx;
}

/* ── 头部 ── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding-top: 24rpx;
}

/* ── 周期筛选 ── */
.period-nav {
  display: flex;
  border-radius: var(--radius-lg);
  padding: 4rpx;
  margin-bottom: 12rpx;
  background: var(--color-surface-muted);
}
.period-btn {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
}
.period-btn--active {
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  color: var(--color-primary);
}
.period-desc {
  display: block;
  text-align: center;
  font-size: var(--text-xs);
  color: var(--color-primary-light);
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

/* ── 概览卡 ── */
.summary-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.summary-card {
  flex: 1;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  background: var(--color-surface-muted);
}
.summary-label {
  display: block;
  margin-bottom: 8rpx;
}
.summary-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.summary-value {
  white-space: nowrap;
}
.summary-unit {
  margin-left: 4rpx;
}
.feeling-stars {
  font-size: 20rpx;
  color: var(--state-warning);
  line-height: 1;
  margin-left: 8rpx;
}

/* ── 图表卡（1RM / 体重共用） ── */
.chart-card {
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 40rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}
.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.chart-legend {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: var(--radius-full);
  display: inline-block;
}
.legend-dot--squat {
  background: var(--color-training-main);
}
.legend-dot--bench {
  background: var(--color-training-assist);
}
.legend-dot--deadlift {
  background: var(--color-warm);
}

/* ── 每周完成 ── */
.weekly-card {
  border-radius: var(--radius-lg);
  margin-bottom: 40rpx;
  overflow: hidden;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}
.weekly-title {
  display: block;
  padding: 32rpx 32rpx 16rpx;
}
.week-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
}
.week-row--bordered {
  border-bottom: 2rpx solid var(--color-border-light);
}
.week-main {
  flex: 1;
  min-width: 0;
}
.week-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.week-label-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.week-label {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.week-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  background: var(--state-info-bg);
  color: var(--state-info);
}
.progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: var(--radius-full);
  overflow: hidden;
  background: var(--color-surface-muted);
}
.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
}
.week-dumbbells {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}
.dumbbell-icon {
  font-size: 28rpx;
}
.week-not-started {
  font-size: var(--text-xs);
}

/* ── 体重最新值 ── */
.weight-latest {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}
.weight-icon {
  font-size: 28rpx;
  color: var(--color-primary-light);
}
.weight-value {
  font-size: var(--text-sm);
}

/* ── 记录体重按钮 ── */
.weight-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}
.weight-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-training-main);
  background: var(--state-info-bg);
  border-radius: var(--radius-full);
}
.weight-btn-icon {
  font-size: 28rpx;
  color: var(--color-training-main);
}
