/* 暂停周期页样式 — 1:1 迁移自 PauseCycle.vue
   px → rpx 按 1px = 2rpx 换算 */

.page {
  min-height: 100vh;
  background: var(--color-surface);
  padding: 0 32rpx 64rpx;
}

.nav-spacer {
  height: 88rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}

.nav-back {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-left: -8rpx;
}

.nav-back-icon {
  font-size: 40rpx;
  color: var(--color-training-main);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-primary);
}

.nav-placeholder {
  width: 64rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.section {
  padding: 0 8rpx;
  margin-bottom: 40rpx;
}

.section-label {
  display: block;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-light);
}

/* 当前进度卡片 */
.progress-card {
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  background: var(--color-surface-muted);
}

.progress-card-label {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.progress-card-text {
  display: block;
  margin-top: 4rpx;
  font-weight: var(--font-weight-semibold);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
}

/* 暂停原因列表 */
.reason-list {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.reason-item {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  text-align: left;
}

.reason-icon {
  font-size: 40rpx;
  color: var(--color-primary-light);
  flex-shrink: 0;
}

.reason-label {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
}

.reason-check {
  font-size: 40rpx;
  color: var(--color-training-main);
  flex-shrink: 0;
}

/* 自定义原因 */
.custom-reason-card {
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.custom-reason-input {
  width: 100%;
  outline: none;
  background: transparent;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
}

/* 时长选择 */
.duration-row {
  display: flex;
  gap: 16rpx;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
}

.duration-btn {
  flex: 1;
  border-radius: var(--radius-lg);
  padding: 20rpx 0;
  text-align: center;
  font-weight: var(--font-weight-medium);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  transition: background var(--duration-fast) var(--ease-default);
}

.custom-date-card {
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.custom-date-col {
  flex: 1;
  text-align: center;
}

.custom-date-label {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

.custom-date-value {
  display: block;
  margin-top: 4rpx;
  font-weight: var(--font-weight-semibold);
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
}

.custom-date-arrow {
  font-size: 32rpx;
  color: var(--color-primary-light);
  flex-shrink: 0;
}

.total-days {
  padding: 0 8rpx;
  margin-top: 24rpx;
  text-align: center;
}

.total-days-text {
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-training-main);
}

/* 受影响训练 */
.affected-card {
  border-radius: var(--radius-lg);
  padding: 32rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.affected-title {
  display: block;
  font-weight: var(--font-weight-semibold);
  margin-bottom: 24rpx;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-primary);
}

.affected-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.affected-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 12rpx 0;
}

.affected-tag {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  border-radius: var(--radius-sm);
  padding: 4rpx 16rpx;
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-training-main);
  background: var(--state-info-bg);
}

.affected-date {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary);
}

/* 确认按钮 */
.confirm-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  padding: 28rpx 48rpx;
  font-weight: var(--font-weight-semibold);
  font-family: var(--font-sans);
  font-size: var(--text-md);
  color: var(--color-surface);
  background-color: var(--color-training-main);
}
