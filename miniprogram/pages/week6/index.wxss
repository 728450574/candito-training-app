/* 第6周决策页样式 — 1:1 迁移自 Week6Decision.vue
   px → rpx 按 1px = 2rpx 换算 */

.page {
  min-height: 100vh;
  background: var(--color-surface);
  padding-bottom: 64rpx;
}

/* ── 导航栏 ── */
.nav-header {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  border-bottom: 2rpx solid var(--color-border);
  background: rgba(255, 255, 255, 0.92);
}

.nav-back-wrap {
  width: 176rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
}

.nav-back-icon {
  font-size: 40rpx;
  color: var(--color-primary);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  letter-spacing: -0.01em;
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.empty-hint {
  margin-bottom: 32rpx;
}

.direct-btn {
  padding: 16rpx 48rpx;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-semibold);
  background: var(--color-training-main);
  color: var(--color-surface);
  font-size: var(--text-sm);
}

/* ── 标题区 ── */
.header-section {
  padding: 48rpx 40rpx 16rpx;
}

.header-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.header-trophy {
  font-size: 40rpx;
  color: var(--state-success);
}

.header-title {
  font-family: var(--font-sans);
  font-size: var(--text-2xl);
  font-weight: var(--font-weight-bold);
  line-height: var(--leading-tight);
  letter-spacing: -0.01em;
  color: var(--color-primary);
}

.header-subtitle {
  display: block;
}

/* ── 第5周数据卡片行 ── */
.lift-data-row {
  padding: 0 40rpx;
  margin-top: 24rpx;
  display: flex;
  gap: 24rpx;
}

.lift-data-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: var(--radius-lg);
  background: var(--color-surface-muted);
  box-shadow: var(--shadow-card);
}

.lift-data-name {
  margin-bottom: 12rpx;
}

.lift-data-weight {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.lift-data-reps {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

/* ── 预估新 1RM 卡片 ── */
.estimate-card {
  margin: 40rpx 40rpx 0;
  padding: 40rpx;
  border-radius: var(--radius-xl);
  background: var(--color-surface);
  box-shadow: var(--shadow-elevated);
}

.estimate-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.estimate-head-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.estimate-icon {
  font-size: 32rpx;
  color: var(--color-training-main);
}

.estimate-title {
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
}

.estimate-subtitle {
  display: block;
  margin-bottom: 32rpx;
}

.estimate-list {
  display: flex;
  flex-direction: column;
}

.estimate-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.estimate-item-name {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary);
}

.estimate-item-right {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.estimate-item-calc {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.estimate-item-value {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-training-main);
}

.estimate-note {
  display: block;
  margin-top: 24rpx;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

/* ── 决策选项区 ── */
.decision-section {
  padding: 48rpx 40rpx 0;
}

.decision-section-title {
  display: block;
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-regular);
  line-height: var(--leading-normal);
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

.decision-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.decision-card {
  width: 100%;
  text-align: left;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  border-left: 6rpx solid transparent;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.decision-card-inner {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.radio-outer {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  border-radius: var(--radius-full);
}

.radio-outer-border {
  border: 4rpx solid var(--color-border);
}

.radio-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--radius-full);
  background: var(--color-surface);
}

.decision-card-body {
  flex: 1;
  min-width: 0;
}

.decision-card-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.decision-card-title {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: var(--font-weight-medium);
  line-height: var(--leading-tight);
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.decision-card-badge {
  display: inline-flex;
  align-items: center;
  border-radius: var(--radius-sm);
  padding: 4rpx 16rpx;
  white-space: nowrap;
  background-color: var(--state-info-bg);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-training-main);
}

.decision-card-desc {
  display: block;
}

/* ── 确认按钮 ── */
.confirm-section {
  padding: 48rpx 40rpx 0;
}

.confirm-btn {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  font-family: var(--font-sans);
  font-size: var(--text-md);
  font-weight: var(--font-weight-semibold);
  background-color: var(--color-training-main);
  color: var(--color-surface);
}
