/* exercise-card 样式
   1:1 迁移自 TrainingDetail.vue 的动作卡片
   使用全局 CSS 变量（见 assets/styles/theme.wxss） */

.exercise-card {
  padding: 32rpx 32rpx;
  margin-bottom: 24rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
  border-radius: var(--radius-lg);
}

/* 头部 */
.ec-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.ec-name {
  font-family: var(--font-sans);
  font-size: var(--text-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: -0.02em;
  line-height: var(--leading-tight);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ec-badge {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* 目标行 */
.ec-target {
  white-space: nowrap;
  margin-bottom: 24rpx;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-primary-light);
}

.ec-target-label {
  color: var(--color-primary-light);
}

.ec-target-value {
  font-family: var(--font-mono);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

/* 组列表 */
.ec-sets {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.ec-set-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
}

.ec-set-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.ec-set-check {
  font-size: 24rpx;
  color: var(--color-surface);
}

.ec-set-label {
  flex: 1;
  min-width: 0;
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ec-set-value {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-weight-semibold);
}

/* 页脚 */
.ec-footer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--color-border-light);
}

.ec-footer-label {
  white-space: nowrap;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

.ec-footer-value {
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-primary-light);
}

.ec-footer-divider {
  color: var(--color-border);
  margin: 0 8rpx;
}
