{
  "compilerOptions": {
    "strict": true,
    "target": "ES2018",
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["../node_modules/@types"],
    "types": ["miniprogram-api-typings"],
    "outDir": ".",
    "rootDir": "."
  },
  "include": ["./**/*.ts"],
  "exclude": ["./**/*.js"]
}
